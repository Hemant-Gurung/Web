{
  "name": "restaurant-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:my-restaurant": "npm run dev --workspace=my-restaurant",
    "dev:verde-kitchen": "npm run dev --workspace=verde-kitchen",
    "dev:server": "npm run dev --workspace=restaurant-server"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.9.3"
  }
}
