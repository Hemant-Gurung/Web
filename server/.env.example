# Supabase connection pooler (Transaction mode) — used by the app at runtime
# Settings → Database → Connection string → Transaction
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Supabase direct connection — used by Prisma for migrations only
# Settings → Database → Connection string → Direct connection
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# The URL of your Next.js frontend (for CORS)
FRONTEND_URL="http://localhost:3000"

# Port the server runs on
PORT=4000

# Environment
NODE_ENV="development"

# JWT — generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-key-change-this"
JWT_EXPIRES_IN="7d"

# Email (add when you integrate Resend)
# RESEND_API_KEY="re_..."
# CONTACT_RECIPIENT_EMAIL="owner@myrestaurant.com"
